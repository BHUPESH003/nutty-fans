/// PostAnalytics - Daily post performance metrics
/// NOTE: This table should be partitioned by date in production
model PostAnalytics {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId      String   @map("post_id") @db.Uuid
  date        DateTime @db.Date
  views       Int      @default(0)
  uniqueViews Int      @default(0) @map("unique_views")
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  purchases   Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(10, 2)

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, date])
  @@index([postId])
  @@index([date])
  @@map("post_analytics")
}

/// CreatorAnalytics - Daily creator performance metrics
/// NOTE: This table should be partitioned by date in production
model CreatorAnalytics {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorId            String   @map("creator_id") @db.Uuid
  date                 DateTime @db.Date
  profileViews         Int      @default(0) @map("profile_views")
  newSubscribers       Int      @default(0) @map("new_subscribers")
  churnedSubscribers   Int      @default(0) @map("churned_subscribers")
  totalSubscribers     Int      @default(0) @map("total_subscribers")
  revenueSubscriptions Decimal  @default(0) @map("revenue_subscriptions") @db.Decimal(10, 2)
  revenuePpv           Decimal  @default(0) @map("revenue_ppv") @db.Decimal(10, 2)
  revenueTips          Decimal  @default(0) @map("revenue_tips") @db.Decimal(10, 2)
  revenueMessages      Decimal  @default(0) @map("revenue_messages") @db.Decimal(10, 2)
  revenueTotal         Decimal  @default(0) @map("revenue_total") @db.Decimal(10, 2)

  // Relations
  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, date])
  @@index([creatorId])
  @@index([date])
  @@map("creator_analytics")
}

/// UserActivity - Track user engagement events
/// NOTE: This table is partitioned by created_at
/// PostgreSQL requires partition key in primary key, hence composite @@id
/// Foreign key constraints cannot be applied to partitioned tables
model UserActivity {
  id           String           @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  activityType UserActivityType @map("activity_type")
  entityType   String?          @map("entity_type") @db.VarChar(50)
  entityId     String?          @map("entity_id") @db.Uuid
  durationMs   Int?             @map("duration_ms")
  metadata     Json             @default("{}")
  ipAddress    String?          @map("ip_address") @db.Inet
  userAgent    String?          @map("user_agent") @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")

  // Note: No FK relation due to partitioning requirements
  // Referential integrity must be maintained at application level

  // Composite primary key required for PostgreSQL partitioning
  @@id([id, createdAt])
  @@index([userId])
  @@index([activityType])
  @@index([entityType, entityId])
  @@map("user_activity")
}

