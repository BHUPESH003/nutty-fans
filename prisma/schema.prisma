/// =============================================================================
/// AUTH & AGE VERIFICATION TABLES
/// =============================================================================

enum VerificationTokenType {
  email_verify
  password_reset
}

enum AgeVerificationStatus {
  pending
  passed
  failed
  needs_review
}

/// Verification tokens for email verification and password resets
model VerificationToken {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  type       VerificationTokenType
  tokenHash  String               @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime             @map("expires_at")
  consumedAt DateTime?            @map("consumed_at")
  createdIp  String?              @map("created_ip") @db.Inet
  userAgent  String?              @map("user_agent") @db.Text
  createdAt  DateTime             @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, expiresAt])
  @@index([tokenHash])
  @@map("verification_tokens")
}

/// Age verification events for users (e.g., Veriff sessions)
model AgeVerification {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  provider          String                @db.VarChar(50)
  providerSessionId String                @map("provider_session_id") @db.VarChar(255)
  status            AgeVerificationStatus @default(pending)
  method            String?               @db.VarChar(50)
  country           String?               @db.VarChar(2)
  dobConfirmed      Boolean?              @map("dob_confirmed")
  livenessScore     Float?                @map("liveness_score")
  fraudScore        Float?                @map("fraud_score")
  failureReason     String?               @map("failure_reason") @db.Text
  expiresAt         DateTime?             @map("expires_at")
  metadata          Json                  @default("{}")
  verifiedAt        DateTime?             @map("verified_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerSessionId])
  @@index([status])
  @@map("age_verifications")
}
