  @@index([tipGoalId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("tip_goal_contributions")
}

/// Bundles - Content bundles for purchase
model Bundle {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorId     String       @map("creator_id") @db.Uuid
  title         String       @db.VarChar(255)
  description   String?      @db.Text
  price         Decimal      @db.Decimal(8, 2)
  originalPrice Decimal?     @map("original_price") @db.Decimal(8, 2)
  coverImageUrl String?      @map("cover_image_url") @db.Text
  itemCount     Int          @default(0) @map("item_count")
  purchaseCount Int          @default(0) @map("purchase_count")
  status        BundleStatus @default(draft)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")

  // Relations
  creator   CreatorProfile   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  items     BundleItem[]
  purchases BundlePurchase[]

  @@index([creatorId])
  @@index([status])
  @@index([creatorId, createdAt(sort: Desc)])
  @@map("bundles")
}

/// BundleItems - Posts included in a bundle
model BundleItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bundleId  String   @map("bundle_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([bundleId, postId])
  @@index([bundleId])
  @@index([postId])
  @@map("bundle_items")
}

/// BundlePurchases - Track bundle purchases
model BundlePurchase {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bundleId      String   @map("bundle_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  pricePaid     Decimal  @map("price_paid") @db.Decimal(8, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  bundle      Bundle      @relation(fields: [bundleId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@unique([bundleId, userId])
  @@index([bundleId])
  @@index([userId])
  @@index([userId, bundleId])
  @@map("bundle_purchases")
}

