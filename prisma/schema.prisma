  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.Inet
  userAgent  String?  @map("user_agent") @db.Text
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  // Note: No FK relation to allow logging for deleted users

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// DmcaRequests - DMCA takedown requests
model DmcaRequest {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complainantName   String     @map("complainant_name") @db.VarChar(255)
  complainantEmail  String     @map("complainant_email") @db.VarChar(255)
  contentUrls       String[]   @map("content_urls")
  originalWorkUrls  String[]   @map("original_work_urls")
