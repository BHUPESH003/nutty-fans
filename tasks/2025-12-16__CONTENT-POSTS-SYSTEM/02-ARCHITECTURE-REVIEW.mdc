```typescript
// Vertical video feed (TikTok-style pagination)
async getReelsFeed(cursor?: string, limit = 10) {
  return postRepo.findMany({
    where: {
      postType: 'reel',
      status: 'published',
      publishedAt: { lte: new Date() },
    },
    orderBy: { publishedAt: 'desc' },
    cursor: cursor ? { id: cursor } : undefined,
    take: limit,
    include: { media: true, creator: true },
  });
}
```

