## 7. Comments Threading Model

### Data Model

```
Comment {
  id
  postId       вҶ’ Post
  userId       вҶ’ User
  parentId     вҶ’ Comment (self-reference, nullable)
  content
  likeCount
  replyCount
  isHidden
  ...
}
```

### Threading Logic

```typescript
// Top-level comments (parentId = null)
const topLevelComments = await commentRepo.findByPostId(postId, {
  where: { parentId: null },
  orderBy: { createdAt: 'desc' },
  take: 20,
});

// Load first 3 replies for each
for (const comment of topLevelComments) {
  comment.replies = await commentRepo.findReplies(comment.id, { take: 3 });
}

// User can "View more replies" вҶ’ loads next page
```

### Comment Creation

```typescript
async create(postId: string, userId: string, input: CreateCommentInput) {
  // 1. Check if post exists and has comments enabled
  const post = await postRepo.findById(postId);
  if (!post || !post.commentsEnabled) throw new Error('Comments disabled');
  
  // 2. Check access (subscriber-only posts)
  const hasAccess = await postService.checkAccess(postId, userId);
  if (!hasAccess) throw new Error('Access denied');
  
  // 3. Create comment
  const comment = await commentRepo.create({ postId, userId, ...input });
  
  // 4. Update counters
  await postRepo.incrementCommentCount(postId);
  if (input.parentId) {
    await commentRepo.incrementReplyCount(input.parentId);
  }
  
  return comment;
}
```

