### 3.3 ESLint Configuration (Flat Config)

**Decision:** ESLint 9.x flat config with Next.js + TypeScript rules.

**File:** `eslint.config.mjs`

**Configuration Structure:**

```javascript
import { FlatCompat } from '@eslint/eslintrc';
import js from '@eslint/js';
import typescriptPlugin from '@typescript-eslint/eslint-plugin';
import typescriptParser from '@typescript-eslint/parser';
import importPlugin from 'eslint-plugin-import';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// FlatCompat is required to use eslint-config-next with ESLint 9 flat config
const compat = new FlatCompat({
  baseDirectory: __dirname,
  recommendedConfig: js.configs.recommended,
});

export default [
  // Global ignores
  {
    ignores: [
      '.next/**',
      'node_modules/**',
      'dist/**',
      'coverage/**',
      'out/**',
      'build/**',
    ],
  },

  // Base JS recommended
  js.configs.recommended,

  // Next.js configuration via FlatCompat
  // eslint-config-next includes React, React Hooks, and Next.js rules
  ...compat.extends('next/core-web-vitals'),

  // TypeScript files - additional rules
  {
    files: ['**/*.ts', '**/*.tsx'],
    languageOptions: {
      parser: typescriptParser,
      parserOptions: {
        project: './tsconfig.json',
        ecmaVersion: 'latest',
        sourceType: 'module',
      },
    },
    plugins: {
      '@typescript-eslint': typescriptPlugin,
      'import': importPlugin,
    },
    rules: {
      // TypeScript strict rules
      '@typescript-eslint/no-explicit-any': 'error',
      '@typescript-eslint/no-unused-vars': ['error', { argsIgnorePattern: '^_' }],
      '@typescript-eslint/explicit-function-return-type': 'off',
      '@typescript-eslint/no-floating-promises': 'error',

      // Import rules
      'import/order': ['error', {
        'groups': [
          'builtin',
          'external',
          'internal',
          'parent',
          'sibling',
          'index',
        ],
        'pathGroups': [
          {
            'pattern': '@/**',
            'group': 'internal',
            'position': 'before',
          },
        ],
        'newlines-between': 'always',
        'alphabetize': {
          'order': 'asc',
          'caseInsensitive': true,
        },
      }],
      'import/no-duplicates': 'error',

      // General rules
      'no-console': ['warn', { allow: ['warn', 'error'] }],
      'prefer-const': 'error',
      'no-var': 'error',
    },
  },
];
```

**Key Implementation Notes:**

| Aspect | Explanation |
|--------|-------------|
| `FlatCompat` | Required to use `eslint-config-next` (legacy format) with ESLint 9 flat config |
| `next/core-web-vitals` | Includes React, React Hooks, and Next.js rules automatically |
| No direct plugin imports | React/React Hooks plugins are included via `eslint-config-next` |

**Rule Justifications:**

| Rule | Setting | Rationale |
|------|---------|-----------|
| `@typescript-eslint/no-explicit-any` | `error` | CODEBASE_GOVERNANCE_RULES §3.1 — `any` forbidden |
| `@typescript-eslint/no-floating-promises` | `error` | Prevent unhandled promise rejections |
| `import/order` | Configured | Consistent import organization |
| `no-console` | `warn` | Allow console.warn/error, flag console.log |

