# ============================================
# NuttyFans Environment Variables
# ============================================
# Copy this file to .env.local for local development
# DO NOT commit .env.local or any file containing real secrets
# 
# Reference: /tasks/2025-12-14__INFRASTRUCTURE-SETUP/02-ARCHITECTURE-REVIEW.mdc
# ============================================

# ============================================
# DATABASE (Neon PostgreSQL)
# ============================================
# Pooled connection string for application runtime
# Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech:5432/dbname?sslmode=require
DATABASE_URL=

# Unpooled connection string for migrations and schema changes
# Use this for: pnpm db:migrate, pnpm db:push
DATABASE_URL_UNPOOLED=

# ============================================
# STORAGE (AWS S3)
# ============================================
# IAM user credentials with S3 access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS region where S3 buckets are located
AWS_REGION=us-east-1

# S3 bucket name (environment-specific)
# Development: nuttyfans-media-dev
# QA: nuttyfans-media-qa
# Production: nuttyfans-media-prod
AWS_S3_BUCKET=

# ============================================
# CDN (AWS CloudFront)
# ============================================
# CloudFront distribution URL for serving media
# Format: https://dxxxxxxxxxx.cloudfront.net
CLOUDFRONT_URL=

# ============================================
# APPLICATION
# ============================================
# Public application URL (accessible to browser)
# Development: http://localhost:3000
# QA: https://nuttyfans-qa.vercel.app
# Production: https://nuttyfans.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
# Options: development, production
NODE_ENV=development

# ============================================
# NOTES
# ============================================
# 
# Environment-Specific Values:
# ----------------------------
# Each environment (dev, qa, prod) uses different values for:
# - DATABASE_URL (different Neon branches)
# - AWS_S3_BUCKET (different buckets)
# - CLOUDFRONT_URL (different distributions)
# - NEXT_PUBLIC_APP_URL (different Vercel URLs)
#
# Where to Set Values:
# --------------------
# - Local development: .env.local (gitignored)
# - CI builds: GitHub Actions secrets (if needed)
# - Deployments: Vercel environment variables
#
# Security Rules:
# ---------------
# - NEVER commit real credentials
# - NEVER log sensitive values
# - NEVER expose server-only vars to client (no NEXT_PUBLIC_ prefix for secrets)
#
# Variable Scope:
# ---------------
# Server-only (no NEXT_PUBLIC_):
#   DATABASE_URL, DATABASE_URL_UNPOOLED
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
#   AWS_REGION, AWS_S3_BUCKET, CLOUDFRONT_URL
#
# Client-accessible (NEXT_PUBLIC_):
#   NEXT_PUBLIC_APP_URL
